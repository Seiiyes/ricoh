# Demo Mode Configuration
# Set to "true" to use demo devices, "false" for real network scanning
DEMO_MODE=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ricoh_provisioning

# Encryption Key for Network Passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# Ricoh Printer Admin Credentials
# These credentials are used to access printer web interface for user management
RICOH_ADMIN_USER=admin
RICOH_ADMIN_PASSWORD=

# Retry Configuration for Automatic Provisioning
# These settings control the retry behavior when provisioning users to printers

# Exponential backoff for BUSY/TIMEOUT errors
RETRY_INITIAL_DELAY=5.0          # Initial delay in seconds (default: 5.0)
RETRY_MAX_DELAY=60.0             # Maximum delay in seconds (default: 60.0)
RETRY_MAX_ATTEMPTS=5             # Maximum retry attempts (default: 5)
RETRY_BACKOFF_MULTIPLIER=2.0     # Exponential multiplier (default: 2.0)

# BADFLOW error handling (anti-scraping protection)
RETRY_BADFLOW_MAX_ATTEMPTS=1     # Retry once after session reset (default: 1)

# Connection error handling
RETRY_CONNECTION_MAX_ATTEMPTS=3  # Maximum connection retry attempts (default: 3)
RETRY_CONNECTION_DELAY=10.0      # Fixed delay for connection errors in seconds (default: 10.0)
