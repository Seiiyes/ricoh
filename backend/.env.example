# =============================================================================
# RICOH EQUIPMENT MANAGEMENT - BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and configure the values for your environment
# For production deployments, ensure all security-related variables are set

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# REQUIRED: Must be set in all environments (no default value for security)
DATABASE_URL=postgresql://ricoh_admin:ricoh_secure_2024@localhost:5432/ricoh_fleet

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment: development, staging, production
# Affects: CSRF protection (enabled by default in production)
ENVIRONMENT=development

# Demo mode: true/false
# When true, uses mock data instead of real printer connections
DEMO_MODE=false

# Debug mode: true/false
# Enables detailed logging and error messages
DEBUG=true

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# SECURITY CONFIGURATION - ENCRYPTION & JWT
# =============================================================================
# ENCRYPTION_KEY: Used for encrypting sensitive data in database (passwords, credentials)
# REQUIRED: Must be set in all environments (no default value for security)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# SECRET_KEY: Used for signing JWT tokens
# REQUIRED: Must have sufficient entropy (at least 3 of: uppercase, lowercase, digits, special chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-with-sufficient-entropy-here

# =============================================================================
# SECURITY CONFIGURATION - CORS
# =============================================================================
# Comma-separated list of allowed origins for CORS
# In production, restrict to your actual frontend domains
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# SECURITY CONFIGURATION - CSRF
# =============================================================================
# CSRF Protection: Enabled by default in production, disabled in development
# Set to 'true' to force enable in development
# ENABLE_CSRF=true

# =============================================================================
# SECURITY CONFIGURATION - REDIS (OPTIONAL)
# =============================================================================
# Redis URL for distributed CSRF token storage and rate limiting
# Required for multi-instance deployments (load balancers)
# If not set, uses in-memory storage (not recommended for production)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# RICOH INTEGRATION CONFIGURATION
# =============================================================================
# Admin password for Ricoh printer web interface
# REQUIRED: Must be set when using Ricoh printer integration
# No default value for security
# RICOH_ADMIN_PASSWORD=your-secure-password-here

# =============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# =============================================================================
# 1. Generate new ENCRYPTION_KEY and SECRET_KEY (don't use example values)
# 2. Set ENVIRONMENT=production
# 3. Configure REDIS_URL for distributed deployments
# 4. Set RICOH_ADMIN_PASSWORD for printer integration
# 5. Restrict CORS_ORIGINS to your actual frontend domains
# 6. Set DEBUG=false
# 7. Use strong, unique passwords for DATABASE_URL
