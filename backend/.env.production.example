# =============================================================================
# RICOH EQUIPMENT MANAGEMENT - PRODUCTION ENVIRONMENT
# =============================================================================
# Este archivo contiene la configuración para PRODUCCIÓN
# Copiar a .env y configurar con valores reales

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string para PRODUCCIÓN
# IMPORTANTE: Usar credenciales seguras y diferentes a desarrollo
DATABASE_URL=postgresql://ricoh_prod_user:CHANGE_THIS_PASSWORD@db-server:5432/ricoh_fleet_prod

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# IMPORTANTE: Debe ser 'production' para habilitar todas las protecciones
ENVIRONMENT=production

# Demo mode: DEBE ser false en producción
DEMO_MODE=false

# Debug mode: DEBE ser false en producción (no exponer errores detallados)
DEBUG=false

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging level: INFO o WARNING en producción (no DEBUG)
LOG_LEVEL=INFO

# =============================================================================
# SECURITY CONFIGURATION - ENCRYPTION & JWT
# =============================================================================
# ENCRYPTION_KEY: CRÍTICO - Generar uno nuevo y único para producción
# NO usar el mismo que desarrollo
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_NEW_KEY_HERE

# SECRET_KEY: CRÍTICO - Generar uno nuevo y único para producción
# NO usar el mismo que desarrollo
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_NEW_SECRET_HERE

# JWT Token expiration (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# SECURITY CONFIGURATION - CORS
# =============================================================================
# IMPORTANTE: Restringir a dominios reales de producción
# Separar múltiples dominios con comas
CORS_ORIGINS=https://ricoh.tuempresa.com,https://www.ricoh.tuempresa.com

# Solo orígenes explícitos; no use regex de LAN en producción
CORS_ALLOW_PRIVATE_NETWORK=false

# =============================================================================
# SECURITY CONFIGURATION - CSRF
# =============================================================================
# CSRF Protection: Habilitado automáticamente en production
# No es necesario configurar ENABLE_CSRF=true

# =============================================================================
# REDIS CONFIGURATION - REQUERIDO PARA PRODUCCIÓN
# =============================================================================
# Redis es OBLIGATORIO para producción multi-instancia
# Usar Redis URL completa (recomendado) O variables individuales

# Opción A: URL completa (RECOMENDADO)
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis-server:6379/0

# Opción B: Variables individuales (alternativa)
# REDIS_HOST=redis-server
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=REDIS_PASSWORD_HERE

# Cache TTL (Time To Live en segundos)
CACHE_TTL_DASHBOARD=300        # 5 minutos
CACHE_TTL_ANALYTICS=3600       # 1 hora
CACHE_TTL_REPORTS=1800         # 30 minutos

# =============================================================================
# RICOH INTEGRATION CONFIGURATION
# =============================================================================
# Admin password para impresoras Ricoh
# IMPORTANTE: Usar contraseña segura y única
RICOH_ADMIN_PASSWORD=CHANGE_THIS_RICOH_PASSWORD

# Timeout para conexiones a impresoras (segundos)
RICOH_TIMEOUT=30

# Reintentos en caso de fallo
RICOH_MAX_RETRIES=3

# =============================================================================
# RATE LIMITING (DDoS Protection)
# =============================================================================
# Límites de requests por IP
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Límites para endpoints específicos
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=100

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Sentry DSN para monitoreo de errores (opcional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log file path
LOG_FILE_PATH=/var/log/ricoh/api.log

# Log rotation
LOG_MAX_BYTES=10485760          # 10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================
# Backup automático de BD
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *       # Diario a las 2 AM
BACKUP_RETENTION_DAYS=30

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
# Forzar HTTPS en producción
FORCE_HTTPS=true

# Certificados SSL (si se manejan en la aplicación)
# SSL_CERT_PATH=/etc/ssl/certs/ricoh.crt
# SSL_KEY_PATH=/etc/ssl/private/ricoh.key

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Workers para Uvicorn (recomendado: 2-4 x número de CPUs)
WORKERS=4

# Conexiones máximas a BD
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Timeout de queries (segundos)
DB_QUERY_TIMEOUT=30

# =============================================================================
# CHECKLIST DE SEGURIDAD PARA PRODUCCIÓN
# =============================================================================
# Antes de desplegar, verificar:
# [ ] ENVIRONMENT=production
# [ ] DEBUG=false
# [ ] ENCRYPTION_KEY generada y única
# [ ] SECRET_KEY generada y única
# [ ] DATABASE_URL con credenciales seguras
# [ ] REDIS_URL configurada correctamente
# [ ] CORS_ORIGINS restringido a dominios reales
# [ ] RICOH_ADMIN_PASSWORD segura
# [ ] LOG_LEVEL=INFO o WARNING
# [ ] FORCE_HTTPS=true
# [ ] Backups configurados
# [ ] Monitoreo configurado (Sentry, etc.)
# [ ] Rate limiting configurado
# [ ] Certificados SSL válidos

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
# 1. NUNCA commitear este archivo con valores reales a Git
# 2. Usar variables de entorno del sistema o secrets manager en producción
# 3. Rotar ENCRYPTION_KEY y SECRET_KEY periódicamente
# 4. Monitorear logs de seguridad regularmente
# 5. Mantener Redis actualizado y seguro
# 6. Configurar firewall para restringir acceso a BD y Redis
# 7. Usar HTTPS/TLS para todas las conexiones
# 8. Implementar backups automáticos y probarlos regularmente
