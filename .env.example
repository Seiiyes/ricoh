# =============================================================================
# RICOH EQUIPMENT MANAGEMENT - FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env for development
# The frontend uses Vite, so all variables must be prefixed with VITE_

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
# URL where the backend API is running
# Development (Docker): http://localhost:8000
# Development (local): http://localhost:8000
# Production: https://api.your-domain.com
VITE_API_URL=http://localhost:8000
