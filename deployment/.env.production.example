# =============================================================================
# RICOH EQUIPMENT MANAGEMENT - PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.production and configure with your production values
# CRITICAL: Generate new keys, do NOT use these example values in production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=ricoh_fleet
POSTGRES_USER=ricoh_admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_FOR_PRODUCTION

# Database connection string (auto-generated from above, or set manually)
DATABASE_URL=postgresql://ricoh_admin:CHANGE_THIS_STRONG_PASSWORD_FOR_PRODUCTION@postgres:5432/ricoh_fleet

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_FOR_PRODUCTION

# =============================================================================
# SECURITY CONFIGURATION - ENCRYPTION & JWT
# =============================================================================
# CRITICAL: Generate new keys for production
# Generate ENCRYPTION_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_NEW_KEY_FOR_PRODUCTION

# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_NEW_KEY_FOR_PRODUCTION

# =============================================================================
# SECURITY CONFIGURATION - CORS
# =============================================================================
# Set to your actual domain(s), comma-separated
# Example: https://ricoh.yourdomain.com,https://www.ricoh.yourdomain.com
CORS_ORIGINS=https://your-domain.com

# =============================================================================
# SECURITY CONFIGURATION - HTTPS
# =============================================================================
# Force HTTPS redirects (recommended for production)
FORCE_HTTPS=true

# =============================================================================
# RICOH INTEGRATION CONFIGURATION
# =============================================================================
# Admin password for Ricoh printer web interface
# REQUIRED for printer provisioning features
RICOH_ADMIN_PASSWORD=CHANGE_THIS_RICOH_PASSWORD

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# API URL that frontend will use (should be your public domain)
FRONTEND_API_URL=https://api.your-domain.com

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your domain name for SSL certificates and Nginx configuration
DOMAIN_NAME=your-domain.com
API_DOMAIN=api.your-domain.com

# =============================================================================
# SSL CERTIFICATE PATHS (if using custom certificates)
# =============================================================================
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# =============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# =============================================================================
# 1. ✅ Generate NEW ENCRYPTION_KEY (do not use development key)
# 2. ✅ Generate NEW SECRET_KEY (do not use development key)
# 3. ✅ Set strong POSTGRES_PASSWORD (minimum 16 characters)
# 4. ✅ Set strong REDIS_PASSWORD (minimum 16 characters)
# 5. ✅ Configure CORS_ORIGINS with your actual domain(s)
# 6. ✅ Set RICOH_ADMIN_PASSWORD for printer integration
# 7. ✅ Configure DOMAIN_NAME and API_DOMAIN
# 8. ✅ Set DEBUG=false
# 9. ✅ Set FORCE_HTTPS=true
# 10. ✅ Obtain SSL certificates (Let's Encrypt recommended)
